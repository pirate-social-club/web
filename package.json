{
  "name": "@pirate/web",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "bun@1.2.21",
  "type": "module",
  "scripts": {
    "locales:generate": "node ./scripts/generate-locales.mjs",
    "dev:web": "node ./scripts/dev.mjs",
    "dev:web-local-shell": "bun run locales:generate && vite --config vite.local.config.ts --mode local-sqlite",
    "dev": "bun run dev:web",
    "dev:init": "rw-scripts dev-init",
    "build:dev": "bun run locales:generate && vite build --mode dev",
    "build:staging": "bun run locales:generate && vite build --mode staging",
    "build:production": "bun run locales:generate && vite build --mode production",
    "build": "bun run locales:generate && vite build",
    "deploy:dev": "bun run build:dev && wrangler deploy --config dist/worker/wrangler.json --name pirate-web-dev",
    "deploy:staging": "bun run build:staging && wrangler deploy --config dist/worker/wrangler.json --name pirate-web-staging",
    "deploy:production": "bun run build:production && wrangler deploy --config dist/worker/wrangler.json --name pirate-web",
    "serve:dist:local": "bun run scripts/serve-dist-local.ts",
    "preview": "bun run locales:generate && vite preview",
    "storybook": "bun run locales:generate && storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "bun run locales:generate && storybook build",
    "worker:run": "bun run locales:generate && rw-scripts worker-run",
    "generate": "bun run locales:generate && wrangler types --include-runtime false",
    "test": "bun test",
    "test:web": "vitest run",
    "test:web:watch": "vitest",
    "smoke:onboarding": "node ./scripts/smoke-onboarding-routes.mjs",
    "types": "bun run locales:generate && tsc --noEmit"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.21.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@selfxyz/core": "^1.2.0-beta.1",
    "@selfxyz/qrcode": "^1.0.22",
    "@veryai/widget": "^1.0.22",
    "@vidstack/react": "^1.12.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-server-dom-webpack": "19.2.4",
    "remark-gfm": "^4.0.1",
    "rwsdk": "1.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.31.2",
    "@cloudflare/workers-types": "4.20260307.1",
    "@phosphor-icons/react": "^2.1.7",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "^29.0.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "6.4.2",
    "vitest": "^4.1.4",
    "wrangler": "4.81.1"
  }
}
