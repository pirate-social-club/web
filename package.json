{
  "name": "@pirate/web",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "packageManager": "bun@1.2.21",
  "type": "module",
  "scripts": {
    "locales:generate": "node ./scripts/generate-locales.mjs",
    "env:check:prod": "node ./scripts/check-vite-env.mjs production VITE_PRIVY_APP_ID VITE_PRIVY_CLIENT_ID",
    "env:check:staging": "node ./scripts/check-vite-env.mjs staging VITE_PRIVY_APP_ID VITE_PRIVY_CLIENT_ID",
    "dev": "bun run locales:generate && vite --port 5173 --strictPort",
    "xmtp:dev:receive": "bun run ./scripts/xmtp-dev-receiver.ts",
    "xmtp:dev:send": "bun run ./scripts/xmtp-dev-send.ts",
    "dev:desktop-shell": "bun run locales:generate && vite --config vite.desktop.config.ts",
    "dev:init": "rw-scripts dev-init",
    "build": "bun run locales:generate && vite build",
    "build:prod": "bun run env:check:prod && bun run build -- --mode production --minify false --sourcemap false",
    "build:staging": "bun run env:check:staging && bun run build -- --mode staging --minify false --sourcemap false",
    "build:desktop-shell": "bun run locales:generate && vite build --config vite.desktop.config.ts",
    "preview": "bun run locales:generate && vite preview",
    "storybook": "bun run locales:generate && storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "bun run locales:generate && storybook build",
    "worker:run": "bun run locales:generate && rw-scripts worker-run",
    "generate": "bun run locales:generate && wrangler types --include-runtime false",
    "deploy:main": "bun run build:prod && wrangler deploy dist/worker/index.js --config wrangler.jsonc --assets dist/client --no-bundle",
    "deploy:main:staging": "bun run build:staging && wrangler deploy dist/worker/index.js --config wrangler.jsonc --env staging --assets dist/client --no-bundle",
    "deploy:public": "wrangler deploy --config wrangler.public.jsonc",
    "deploy:public:staging": "wrangler deploy --config wrangler.public.jsonc --env staging",
    "test": "bun test",
    "boundary:audit": "node ./scripts/boundary-audit.mjs",
    "agents:openclaw:challenge": "node ./scripts/build-openclaw-challenge.mjs",
    "ui:audit": "node ./scripts/ui-audit.mjs",
    "validate": "bun run locales:generate && bun run types && bun run boundary:audit && bun test && bun run ui:audit",
    "types": "bun run locales:generate && tsgo --noEmit -p tsconfig.app.json",
    "types:stories": "tsgo --noEmit -p tsconfig.stories.json",
    "types:tests": "tsgo --noEmit -p tsconfig.tests.json",
    "types:safe": "bun run locales:generate && node ./scripts/run-types-safely.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@fontsource/anton": "^5.2.7",
    "@pirate/api-contracts": "file:../api/services/contracts",
    "@privy-io/react-auth": "^3.21.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@selfxyz/qrcode": "^1.0.22",
    "@selfxyz/sdk-common": "^1.0.0",
    "@story-protocol/core-sdk": "^1.4.4",
    "@veryai/widget": "^1.0.22",
    "@vidstack/react": "^1.12.13",
    "@web3icons/react": "^4.1.17",
    "@xmtp/browser-sdk": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "19.2.4",
    "react-circle-flags": "^0.0.29",
    "react-dom": "19.2.4",
    "rwsdk": "^1.3.0-canary.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "viem": "^2.48.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.35.0",
    "@cloudflare/workers-types": "4.20260307.1",
    "@phosphor-icons/react": "^2.1.7",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@xmtp/node-sdk": "^6.0.0",
    "linkedom": "^0.18.12",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "wrangler": "4.81.1"
  }
}
